<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMInhasCompras.Views.RelatorioCategoria"
             Title="RelatorioCategoria">

    <StackLayout Padding="15" Spacing="10">

        <Label Text="Total gasto por categoria"
               FontSize="18"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0, 10, 0, 10" />

        <Frame Padding="0" VerticalOptions="FillAndExpand">
            <ListView x:Name="lst_relatorio">
                <ListView.Header>
                <Grid ColumnDefinitions="*, *"
                      BackgroundColor="{StaticResource Gray100}"
                      Padding="10,5">
                    <Label Grid.Column="0" Text="Categoria" VerticalTextAlignment="Center" />
                    <Label Grid.Column="1" Text="Total Gasto" VerticalTextAlignment="Center" HorizontalTextAlignment="End" />
                </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Grid ColumnDefinitions="*, *" Padding="10,8">
                                <Label Grid.Column="0" Text="{Binding Categoria}" VerticalTextAlignment="Center" FontSize="15" />
                                <Label Grid.Column="1" Text="{Binding TotalFormtado}" HorizontalTextAlignment="End" 
                                       VerticalTextAlignment="Center" FontSize="15" 
                                       FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.Footer>
                    <Grid ColumnDefinitions="*, *"
                          BackgroundColor="{StaticResource Gray200}"
                          Padding="10,8">
                        <Label Grid.Column="0" Text="TOTAL GERAL" VerticalTextAlignment="Center" FontAttributes="Bold" />
                        <Label x:Name="lbl_total_geral" Grid.Column="1" HorizontalTextAlignment="End"
                               VerticalTextAlignment="Center" FontAttributes="Bold" FontSize="15" />
                    </Grid>
                </ListView.Footer>
            </ListView>
        </Frame>
    </StackLayout>    
</ContentPage>